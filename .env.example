# Copie ce fichier en ".env" (sans le ".example") et remplis tes vraies valeurs.
# Le fichier ".env" ne doit JAMAIS être partagé ou commité dans git (il contient
# ton mot de passe SMTP).

# ================================
# Alertes par email (optionnel)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.compte@gmail.com
SMTP_PASSWORD=ton-mot-de-passe-application
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=ton.compte@gmail.com
ALERT_EMAIL_TO=toi@example.com
# "info" | "warning" | "critical" — sévérité minimale déclenchant un email
ALERT_EMAIL_MIN_SEVERITY=critical

# ================================
# Seuils de ré-entraînement (optionnel, valeurs par défaut sinon)
# ================================
# RETRAIN_THRESHOLD=20
# PERFORMANCE_R2_THRESHOLD=0.60
# MODEL_STALE_DAYS=30
# MAX_CONSECUTIVE_PREDICT_ERRORS=3

# ================================
# Sécurité admin (optionnel, désactivée si vide)
# ================================
# ADMIN_API_KEY=une-cle-secrete-a-toi

# ================================
# Version de l'app mobile (optionnel, valeurs par défaut sinon)
# ================================
# DEFAULT_LATEST_APP_VERSION=1.0.0
# DEFAULT_MIN_SUPPORTED_APP_VERSION=1.0.0
# DEFAULT_UPDATE_URL=
# DEFAULT_UPDATE_MESSAGE=Une nouvelle version de l'application est disponible.
